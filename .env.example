# ============================================
# Matrimony Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Environment
NODE_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:4000
VITE_S3_BUCKET_URL=http://localhost:4566
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_COGNITO_USER_POOL_ID=local_pool_id
VITE_COGNITO_CLIENT_ID=local_client_id

# Backend
AWS_REGION=ap-south-1
DYNAMODB_ENDPOINT=http://localhost:8000
COGNITO_USER_POOL_ID=local_pool_id
COGNITO_CLIENT_ID=local_client_id
SES_FROM_EMAIL=noreply@example.com
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
S3_MEDIA_BUCKET=matrimony-media-dev
CORS_ALLOWED_ORIGINS=http://localhost:3000
